#!/bin/bash
# Blocks direct pushes to main.
# Install once per clone: git config core.hooksPath .githooks

protected_branch="main"

while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/$protected_branch" ]]; then
    echo ""
    echo "  ✋ Direct push to '$protected_branch' is blocked."
    echo ""
    echo "  Workflow:"
    echo "    git checkout -b your-branch-name"
    echo "    git push -u origin your-branch-name"
    echo "    gh pr create"
    echo ""
    echo "  To bypass (emergencies only): git push --no-verify"
    echo ""
    exit 1
  fi
done

exit 0
